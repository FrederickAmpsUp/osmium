#include <Arduino.h>
#include <cstdio>
#include "logging/logger.hpp"
#include "logging/stream_sink.hpp"

#include "drivers/rs485.hpp"
#include "drivers/nodebus_parser.hpp"
#include "drivers/nodebus_sender.hpp"

using namespace osmium;

static constexpr int RX485 = 18;
static constexpr int TX485 = 17;
static constexpr int DD485 = 16;
RS485 rs485(RX485, TX485, DD485);

#define BOARD 2

void setup() {
  static Logger &log = Logger::global();
  static StreamSink ser_sink = { Serial };

  Serial.begin(115200); // change me
  rs485.begin(115200);
  
  log.set_level(LogLevel::TRACE);
  ser_sink.set_level(LogLevel::TRACE);

  log.add_sink(ser_sink);

  log.debug("ready");
}

void loop() {
  static Logger &log = Logger::global();
  static int loops = 0;
  static unsigned long long start_millis = millis();
  
#if BOARD == 3
  static NodebusParser nodebus_parser = { BOARD };
  if (nodebus_parser.update(rs485) > 0) {
    log.info("Recieved packet:");
    log.info("  %s", nodebus_parser.get_payload());
  }
#endif

#if BOARD == 2
  static NodebusSender nodebus_sender = { BOARD };

  if (millis() - start_millis > 1000) {
    int avg_ips = 1000 * loops / (millis() - start_millis);
  
    uint8_t payload[256];
    size_t payload_size = snprintf((char*)payload, 256, "Average IPS: %d", avg_ips);

    nodebus_sender.send(rs485, 3, payload, payload_size);
    log.info("AVERAGE IPS: %d", avg_ips);

    loops = 0;
    start_millis = millis();
  }
#endif

  delay(10);

  ++loops;
}
